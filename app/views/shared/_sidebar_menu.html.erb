  
<div class="flex">
  <div class="w-1/2 bg-gray-200 p-4 rounded-lg shadow-lg">
    <h2 class="font-bold text-xl mb-4">Categories</h2>
    <ul>
      <% @categories.each do |category| %>
        <li class="mb-2">
          <h3 class="font-semibold text-lg"><%= category.name %></h3>
          <ul class="ml-4">
            <% category.subcategories.each do |subcategory| %>
              <li>
                <a href="#" class="text-blue-500 hover:underline"><%= subcategory.name %></a>
              </li>
            <% end %>
          </ul>
        </li>
      <% end %>
    </ul>
  </div>
  <div class="flex-grow">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @notes.each do |note| %>
        <div class="card background-gray-100 p-4 rounded-lg shadow-lg">
          <div class="card-header">
            <h5 class="card-title font-bold text-2xl text-neutral-600"><%= note.subcategory.category.name %></h5>
            <h5 class="card-title font-bold text-normal text-neutral-400"><%= note.subcategory.name %></h5>
          </div>
          <div class="card-body">
            <p class="m-5">
              <figure>
                <img class="rounded-2xl" src="https://placehold.co/600x400?text=nenhuma+foto" alt="image">
              </figure>
            </p>
            <p class="card-text p-2 "><%= note.content %></p>
          </div>
          <div class="p-2 font-medium text-neutral-500">
            Tags:<% note.tags.each do |tag| %>
              <a href="#<%= tag.name %>" class="tag text-red-500"><%= tag.name %></a>
            <% end %>
          </div>
          <div class="card-footer">
            <small class="text-muted">Criado em: <%= note.created_at.strftime("%d/%M/%Y") %></small>
          </div>
        </div>
      <% end %>
      Total de notas: <%= @notes.count %>
    </div>
  </div>
</div>