<div class="my-32" data-controller="highlight" data-highlight-term-value="<%= params[:busca] %>">
  <div class="mx-auto">
    <div class="flex space-x-4">
      <%= render "shared/menu_category" %>
      </div>

      <div class="flex-1">
        <% if @notes.any? %>
          <div class="columns-1 md:columns-2 lg:columns-3 gap-4">
            <% @notes.each do |note| %>
              <div class="break-inside-avoid mb-4 block group card bg-white border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300 w-full overflow-hidden">
                <div class="card-body p-4">


                  <div class="prose prose-base max-w-none text-gray-800 leading-tight">
                    <%= sanitize(note.content) %>
                  </div>

                  <div class="mt-4 pt-2 border-t border-gray-50 flex items-center justify-between group-hover:opacity-80 transition-opacity duration-200">
                  <% if note.tags.any? %>
                    <div class="flex flex-wrap gap-1 mb-2">
                      <% note.tags.each do |tag| %>
                        <%= link_to tag.name, notes_path(busca: tag.name, category: params[:category]), class: "badge badge-ghost badge-xs text-[10px] uppercase px-1.5 py-2 hover:bg-slate-800 hover:text-white transition duration-300" %>
                      <% end %>
                    </div>
                  <% end %>
                    <div class="flex gap-1">
                      <%= link_to edit_note_path(note), data: { turbo_frame: :modal }, class: "btn btn-ghost btn-xs text-primary px-1" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                        </svg>
                      <% end %>
                      <%# <%= link_to note_path(note), class: "btn btn-ghost btn-xs text-info px-1" do %>
                        <%# <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg> Visualizar %>
                      <%# end %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-10 text-gray-500">
            Nenhuma nota encontrada.
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= turbo_frame_tag :modal %>
