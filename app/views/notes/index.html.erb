<%
  typesense_host = ENV['TYPESENSE_HOST'].to_s
  typesense_key  = ENV['TYPESENSE_SEARCH_KEY'].to_s
%>

<div class="my-32"
     data-controller="typesense"
     data-typesense-host-value="<%= typesense_host %>"
     data-typesense-api-key-value="<%= typesense_key %>"
     data-typesense-protocol-value="https"
     data-typesense-port-value="443">

  <div class="mx-auto">
    <div class="flex gap-6">
          <div id="ais-stats" class="mb-3 pl-1 hidden"></div>
      <%# ── Sidebar ── %>
      <aside class="w-72 shrink-0 hidden md:block">
        <div class="w-full p-4 rounded-lg sticky top-8">



          <%# Contador de resultados %>


          <%# Limpar filtros %>


          <%# Filtro por categoria %>
          <div class="mb-1">
            <p class="text-lg font-semibold uppercase text-gray-400 px-1 mb-1">Categorias</p>
            <div id="ais-category-filter"></div>
          </div>

          <%# Filtro por subcategoria %>
          <div class="mt-3">
            <p class="text-lg font-semibold uppercase text-gray-400 px-1 mb-1">Subcategorias</p>
            <div id="ais-subcategory-filter"></div>
          </div>

        </div>
      </aside>

      <%# ── Conteúdo principal ── %>
      <div class="flex-1 min-w-0">

        <%# Resultados (hits) %>
        <div id="ais-hits" class="w-full"></div>

        <%# Paginação %>
        <div id="ais-pagination" class="mt-4"></div>

      </div>
    </div>
  </div>
</div>

<%= turbo_frame_tag :modal %>
