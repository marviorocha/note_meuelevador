<%= turbo_frame_tag :modal do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50" data-controller="modal" data-action="keydown.esc->modal#close">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl mx-4 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center bg-gray-50">
        <h3 class="text-lg font-semibold text-gray-800">Nova Nota</h3>
        <%= link_to notes_path, class: "text-gray-400 hover:text-gray-600", data: { turbo_frame: "_top" } do %>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>

      <div class="p-6">
        <%= render "form", note: @note %>
      </div>
    </div>
  </div>
<% end %>
