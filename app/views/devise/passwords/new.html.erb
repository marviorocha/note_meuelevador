<div class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="bg-base-100 p-8 rounded-lg shadow-lg w-full max-w-md">
    <h2 class="text-2xl font-bold mb-6 text-center text-base-content">Redefinir senha</h2>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-base-content font-semibold mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered input-xl w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>
      <%= f.submit "Enviar instruções", class: "btn btn-primary w-full font-bold py-2 px-4 rounded-lg transition" %>
    <% end %>
    <div class="mt-6 text-center">
      <%= link_to "Voltar para login", new_session_path(resource_name), class: "text-blue-500 hover:underline" %>
    </div>
  </div>
</div>
