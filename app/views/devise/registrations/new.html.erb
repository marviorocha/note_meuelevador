<div class="h-screen flex items-center justify-center bg-gray-50 overflow-hidden">
  <div class="bg-base-100 p-8 rounded-lg shadow-lg w-full max-w-md">
    <h2 class="text-2xl font-bold mb-6 text-center text-base-content">Registrar-se</h2>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-base font-semibold mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-md input-bordered w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>
      <div class="mb-4">
        <%= f.label :password, class: "block text-base font-semibold mb-2" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "input input-md input-bordered w-full input-secondary px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>
      <div class="mb-6">
        <%= f.label :password_confirmation, class: "block text-base font-semibold mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-md input-bordered w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>
      <%= f.submit "Registrar-se", class: "btn cursor-pointer w-full btn-primary transition" %>
    <% end %>
    <div class="mt-6 text-center">
      <%= link_to "Já possui conta? Entrar", new_session_path(resource_name), class: "cursor-pointer text-blue-500 hover:underline" %>
    </div>
  </div>
</div>
