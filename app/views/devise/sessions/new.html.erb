<div class="min-h-screen flex  items-center justify-center bg-gray-50 overflow-x-hidden overflow-y-hidden">
  <div class="bg-base-100 p-8 rounded-lg shadow-lg w-full max-w-md">
    <h2 class="text-2xl font-bold mb-6 text-center text-base-content">Entrar</h2>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-base-content font-semibold mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-2 input input-bordered rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>
      <div class="mb-6">
        <%= f.label :password, class: "block text-base-content font-semibold mb-2" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-4 py-2 input input-bordered rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>
      <div class="flex items-center justify-between mb-4">
        <%= f.check_box :remember_me, class: "mr-2" %>
        <%= f.label :remember_me, class: "text-gray-600" %>
        <%= link_to "Esqueceu a senha?", new_password_path(resource_name), class: "text-blue-500 hover:underline ml-auto" %>
      </div>
      <%= f.submit "Entrar", class: "w-full btn btn-neutral text-white font-bold py-2 px-4 rounded-lg  transition" %>
    <% end %>
    <div class="mt-6 text-center">
      <%#= link_to "Registrar-se", new_registration_path(resource_name), class: "text-blue-500 hover:underline" %>
    </div>
  </div>
</div>
