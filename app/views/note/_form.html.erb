<%= form_with(model: note, class: "space-y-4") do |f| %>
  <% if note.errors.any? %>
    <div class="bg-red-50 text-red-700 p-4 rounded-md">
      <h2 class="font-bold"><%= pluralize(note.errors.count, "erro") %> impediram esta nota de ser salva:</h2>
      <ul class="list-disc ml-5">
        <% note.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :content, "Conteúdo", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :content, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :author_id, "Autor", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :author_id, Author.all, :id, :name, { prompt: "Selecione o Autor" }, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2" } %>
    </div>

    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :status, Note.statuses.keys.map { |s| [s.titleize, s] }, {}, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2" } %>
    </div>
  </div>

  <div>
    <%= f.label :subcategory_id, "Subcategoria (Inclui Categoria)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.grouped_collection_select :subcategory_id, Category.all, :subcategories, :name, :id, :name, { prompt: "Selecione a Subcategoria" }, { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2" } %>
  </div>

  <div>
    <%= label_tag :tag_names, "Tags (separadas por vírgula)", class: "block text-sm font-medium text-gray-700" %>
    <%= text_field_tag :tag_names, note.tags.map(&:name).join(", "), class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2" %>
  </div>

  <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200">
    <%= link_to "Cancelar", note_index_path, class: "btn btn-ghost", data: { turbo_frame: "_top" } %>
    <%= f.submit "Salvar Alterações", class: "btn btn-primary" %>
  </div>
<% end %>
